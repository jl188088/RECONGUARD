{
  "entities": {
    "Vulnerability": {
      "title": "Vulnerability",
      "description": "An identified security flaw.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "target": { "type": "string" },
        "type": { "type": "string" },
        "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
        "status": { "type": "string", "enum": ["open", "mitigated", "ignored"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "uid": { "type": "string", "description": "The user ID who owns this record." }
      },
      "required": ["id", "target", "type", "severity", "status", "timestamp", "uid"]
    },
    "ScanHistoryEntry": {
      "title": "ScanHistoryEntry",
      "description": "A record of a completed or failed scan.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "target": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["completed", "failed", "interrupted"] },
        "report": { "type": "string" },
        "intensity": { "type": "string" },
        "mode": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["id", "target", "date", "status", "report", "uid"]
    },
    "ScanPreset": {
      "title": "ScanPreset",
      "description": "A saved scan configuration.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "intensity": { "type": "string" },
        "mode": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["id", "name", "intensity", "mode", "uid"]
    },
    "LogEntry": {
      "title": "LogEntry",
      "description": "A system log message.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string" },
        "level": { "type": "string", "enum": ["info", "warn", "error", "success"] },
        "message": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["id", "timestamp", "level", "message", "uid"]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "displayName": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/vulnerabilities/{vulnId}": {
      "schema": "Vulnerability",
      "description": "Collection of all identified vulnerabilities."
    },
    "/scanHistory/{scanId}": {
      "schema": "ScanHistoryEntry",
      "description": "History of all reconnaissance scans."
    },
    "/scanPresets/{presetId}": {
      "schema": "ScanPreset",
      "description": "User-defined scan configurations."
    },
    "/logs/{logId}": {
      "schema": "LogEntry",
      "description": "System logs for the current session."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and permissions."
    }
  }
}
